generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// CORE & MULTI-TENANCY
// ==========================================

model Tenant {
  id                  String   @id @default(cuid())
  name                String
  slug                String?  @unique
  rut                 String?  @unique
  razonSocial         String?
  giro                String?
  direccionTributaria String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  users      User[]
  customers  Customer[]
  products   Product[]
  categories Category[]
  orders     Order[]
  dtes       DocumentDTE[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  USER
  MANAGER_SUCURSAL
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  accounts Account[]
  sessions Session[]

  @@index([tenantId])
}

// ==========================================
// CRM: CUSTOMERS
// ==========================================

model Customer {
  id        String   @id @default(cuid())
  rut       String?  @unique // Clave para Facturas B2B
  name      String
  email     String?
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders   Order[]

  @@index([tenantId])
  @@index([rut])
}

// ==========================================
// PRODUCT & INVENTORY MANAGEMENT (PIM)
// ==========================================

model Category {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenantId String
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([tenantId])
}

model Product {
  id          String   @id @default(cuid())
  sku         String? // Control unitario
  name        String
  description String?  @db.Text
  price       Float    @default(0)
  stock       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  images     ProductImage[]
  orderItems OrderItem[]

  @@index([tenantId])
  @@index([categoryId])
  @@index([sku])
}

model ProductImage {
  id        String   @id @default(cuid())
  url       String // Storage in AWS S3 or Cloudinary
  altText   String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// ==========================================
// SALES & ORDER MANAGEMENT
// ==========================================

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  COMPLETED
  CANCELLED
}

enum PaymentGateway {
  MERCADOPAGO
  WEBPAY_PLUS
  CRYPTO
  MACH
  TENPO
  OTHER
}

model Order {
  id          String      @id @default(cuid())
  orderNumber Int         @unique @default(autoincrement()) // Referencia interna UI
  status      OrderStatus @default(PENDING)
  totalAmount Float       @default(0)

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  paymentMethod PaymentGateway?
  paymentId     String? // Token WP Plus / ID MercadoPago
  paymentStatus String? // Detalles síncronos de la pasarela

  items OrderItem[]
  dte   DocumentDTE?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([customerId])
  @@index([orderNumber])
}

model OrderItem {
  id         String @id @default(cuid())
  quantity   Int    @default(1)
  unitPrice  Float  @default(0)
  totalPrice Float  @default(0)

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}

// ==========================================
// TAX COMPLIANCE (SII CHILE - DTE)
// ==========================================

enum DTEType {
  BOLETA_ELECTRONICA // Code 39
  FACTURA_ELECTRONICA // Code 33
  GUIA_DESPACHO // Code 52
  NOTA_CREDITO // Code 61
  NOTA_DEBITO // Code 56
}

enum DTEStatus {
  PENDING
  GENERATED
  ACCEPTED_SII
  REJECTED_SII
  ACCEPTED_CUSTOMER
  REJECTED_CUSTOMER
}

model DocumentDTE {
  id     String    @id @default(cuid())
  type   DTEType
  folio  Int?
  status DTEStatus @default(PENDING)

  // Storage for immutable 6-year retention rule
  xmlUrl String? // Immutable AWS S3 Link
  pdfUrl String?
  cafUrl String? // Código de Autorización de Folios xml

  // Tracking timelines (SII 8 Day rule)
  issuedAt   DateTime?
  acceptedAt DateTime?

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([orderId])
  @@index([folio])
}
